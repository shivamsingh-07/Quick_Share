<?xml version="1.0" encoding="utf-8"?>
<!--
  Bluetooth icon — classic "rune" glyph (vertical bar + two diagonal
  bow-tie strokes meeting at the centre).

  Stroke-only, transparent fill, 48x48 viewBox to match the rest of
  the icon set (ic_settings, ic_send, ic_receive, ic_quick_share).
  Stroke width is 3.0 / 48 viewport ≈ 6.25 % so the line weight reads
  the same as the other icons regardless of display size.

  Tinting: use Compose `Icon(tint = ...)` or `ColorFilter.tint(...)`
  to repaint at the call site — the source path uses #FF000000 so
  un-tinted previews remain legible.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="48"
    android:viewportHeight="48">
    <path
        android:pathData="M16,14 L32,32 L24,40 L24,8 L32,16 L16,34"
        android:fillColor="#00000000"
        android:strokeColor="#FF000000"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
